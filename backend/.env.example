# =====================================================
# Pinner Backend 환경변수 참조 파일
# 실제 값은 절대 이 파일에 입력하지 마세요.
#
# [Local]  IntelliJ > Run Configuration > VM Options
#          예: -DDB_HOST=xxx -DDB_PASSWORD=xxx
# [Dev/Prod] 서버 환경변수 또는 Docker env 설정
# =====================================================

# Database
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# Redis
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# JWT (Secret: 최소 32자 이상 랜덤 문자열)
JWT_SECRET=
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=1209600000

# Storage (생략 시 profile 기본값 사용)
# local  기본값: D:/EGOVFRAME/project/uploads
# dev    기본값: /home/app/pinner/uploads
# prod   기본값: /home/app/pinner/uploads
STORAGE_PATH=

# CORS (dev/prod 배포 시 실제 도메인으로 설정)
CORS_ALLOWED_ORIGINS=http://localhost:5173

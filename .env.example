# ================================================================
# Pinner .env.example
# 이 파일을 복사해서 환경별 파일을 만드세요:
#   cp .env.example .env.local   # 로컬 Docker 개발용
#   cp .env.example .env.dev     # 개발 서버용
#   cp .env.example .env.prod    # 운영 서버용
# ================================================================

# ----------------------------------------------------------------
# Frontend (Vite 빌드 시 번들에 포함 — 절대 시크릿 넣지 말 것)
# ----------------------------------------------------------------
VITE_GOOGLE_MAPS_API_KEY=

# ----------------------------------------------------------------
# Backend — Database (MariaDB)
# ----------------------------------------------------------------
# Docker 내부에서는 컨테이너 이름 사용 (mariadb)
# 외부 DB 사용 시 실제 호스트/IP 입력
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=pinner_local
DB_USERNAME=pinner
DB_PASSWORD=

# ----------------------------------------------------------------
# Backend — Redis
# ----------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
# 비밀번호 없이 사용할 경우 빈칸으로 두세요
REDIS_PASSWORD=

# ----------------------------------------------------------------
# Backend — JWT
# ----------------------------------------------------------------
# JWT_SECRET: 최소 32자 이상 랜덤 문자열 (운영 환경에서는 반드시 변경)
# 생성 예: openssl rand -base64 48
JWT_SECRET=
# 단위: 밀리초 / 기본값: 15분 / 운영 권장: 900000 (15분)
JWT_ACCESS_EXPIRATION=900000
# 단위: 밀리초 / 기본값: 14일 / 운영 권장: 1209600000 (14일)
JWT_REFRESH_EXPIRATION=1209600000

# ----------------------------------------------------------------
# Backend — Storage
# ----------------------------------------------------------------
# 컨테이너 내부 경로 (docker-compose volume mount 경로와 일치)
STORAGE_PATH=/app/uploads

# ----------------------------------------------------------------
# Backend — CORS
# ----------------------------------------------------------------
# 브라우저가 접근하는 실제 주소 (nginx 포트 포함)
# local Docker: http://localhost
# dev 서버:     http://dev.pinner.com  또는  http://서버IP
# prod 서버:    https://pinner.com
# 로컬 직접 실행(npm run dev + ./gradlew bootRun): http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost

# ----------------------------------------------------------------
# MariaDB Docker 초기화 (docker-compose에서만 사용)
# DB_USERNAME / DB_PASSWORD 와 동일한 값으로 설정
# ----------------------------------------------------------------
MYSQL_ROOT_PASSWORD=
MYSQL_DATABASE=pinner_local
MYSQL_USER=pinner
MYSQL_PASSWORD=

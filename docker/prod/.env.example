# =====================================================
# Pinner Prod 환경변수 — cp .env.example .env 후 수정
# =====================================================

# Database (NAS에서 직접 실행 중인 MariaDB)
DB_HOST=192.168.0.17
DB_PORT=13306
DB_NAME=pinner_prod
DB_USERNAME=root
DB_PASSWORD=

# Redis (NAS에서 직접 실행 중인 Redis)
REDIS_HOST=192.168.0.17
REDIS_PORT=6379

# JWT (dev와 다른 별도 랜덤 문자열 사용 권장)
# 생성: openssl rand -hex 32
JWT_SECRET=
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=1209600000

# CORS — 브라우저에서 접근하는 실제 도메인
CORS_ALLOWED_ORIGINS=https://pinner.ptory.net/

# 데모 계정
DEMO_PASSWORD=

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=
VITE_DEMO_ENABLED=true

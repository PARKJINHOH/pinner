# =====================================================
# Pinner Dev 환경변수
# cp .env.example .env 후 값을 채워주세요
# =====================================================

# Database
DB_ROOT_PASSWORD=
DB_USERNAME=
DB_PASSWORD=

# Redis
REDIS_PASSWORD=

# JWT (최소 32자 이상 랜덤 문자열)
# 생성 예: openssl rand -hex 32
JWT_SECRET=

# CORS (프론트엔드 접근 도메인 - NPM 도메인 또는 내부 IP:포트)
# 예: https://dev.yourdomain.com 또는 http://192.168.0.17:30000
CORS_ALLOWED_ORIGINS=

# 데모 계정 비밀번호
DEMO_PASSWORD=

# Google Maps API Key
VITE_GOOGLE_MAPS_API_KEY=

# 데모 버튼 표시 여부
VITE_DEMO_ENABLED=false
